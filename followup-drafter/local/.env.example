# Copy this file to .env and fill in real values.
# Leave HUBSPOT_TOKEN or OPENAI_API_KEY blank and the app runs in demo mode
# with 3 example prospects, so you can see it working before connecting anything.

# HubSpot private app token (Settings -> Integrations -> Private Apps)
HUBSPOT_TOKEN=

# The HubSpot owner ID for whoever's overdue tasks should be pulled (Kim's user)
# Find it at: Settings -> Users & Teams -> click the user -> the ID is in the URL
HUBSPOT_OWNER_ID=

# Notion internal integration secret (notion.so/my-integrations)
NOTION_TOKEN=

# OpenAI API key (platform.openai.com/api-keys)
OPENAI_API_KEY=

# Optional: server port (default 3000)
PORT=3000

# Optional: cron schedule for the automatic morning run (default: 7am Mon-Fri)
# Format: minute hour day-of-month month day-of-week
# Only used by server.js's in-process node-cron. The GitHub Actions workflow
# (../.github/workflows/daily-followup-drafts.yml) has its own schedule,
# set in UTC, independent of this value.
CRON_SCHEDULE=0 7 * * 1-5

# Optional: Slack incoming webhook URL. If set, run-once.js posts each
# morning's drafts to that channel in addition to writing digest.json.
SLACK_WEBHOOK_URL=
