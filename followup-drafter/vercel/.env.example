# For local testing with `vercel dev` only. On Vercel itself, set these
# under Project -> Settings -> Environment Variables instead.
#
# KV_REST_API_URL and KV_REST_API_TOKEN are added automatically once you
# connect a Vercel KV store to this project -- don't set them by hand,
# pull them with `vercel env pull` instead.

HUBSPOT_TOKEN=
HUBSPOT_OWNER_ID=
NOTION_TOKEN=

# Groq API key -- free, no billing required (console.groq.com/keys). This
# is the default LLM provider; leave OPENAI_API_KEY below unset to use it.
GROQ_API_KEY=
# Optional: override the Groq model (default: llama-3.1-8b-instant)
GROQ_MODEL=

# OpenAI API key (platform.openai.com/api-keys) -- paid, needs billing set
# up. Only used as a fallback if GROQ_API_KEY above is not set.
OPENAI_API_KEY=
